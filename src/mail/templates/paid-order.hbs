<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tu Viaje está Confirmado - Bus Express</title>
  <style>
    /* TODO: Copiar TODO el CSS del archivo original */
    /* Incluir todos los estilos exactamente igual */
  </style>
</head>
<body style="margin: 0; padding: 0; width: 100%; background-color: #eaedf2">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #eaedf2; width: 100%">
    <tr>
      <td align="center" valign="top" style="padding: 44px 16px 60px">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="max-width: 420px; width: 100%; background-color: #ffffff; border-radius: 22px; box-shadow: 0 10px 30px rgba(20, 83, 162, 0.13); overflow: hidden;">
          
          <!-- Header -->
          <tr>
            <td align="center" style="background-color: #ffffff; padding: 18px 28px 14px">
              <img src="https://www.toasgroup.com/assets/logo/toas_hor_icon.png" alt="Bus Express" width="160" height="32" style="display: block; max-width: 160px; height: auto" />
            </td>
          </tr>

          <!-- Success Icon -->
          <tr>
            <td align="center" style="padding: 48px 36px 30px">
              <img src="data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='84' height='84' viewBox='0 0 84 84'%3E%3Ccircle cx='42' cy='42' r='42' fill='%234e891f'/%3E%3Cpolyline points='58,28 37,54 25,42' fill='none' stroke='white' stroke-width='6' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E" alt="Confirmado" width="84" height="84" style="display: block; margin: 0 auto 26px" />
              <h1 style="margin: 0 0 14px; font-size: 27px; font-weight: 900; color: #1453a2; line-height: 1.2; text-align: center;">¡Tu Viaje está<br />Confirmado!</h1>
              <p style="margin: 0; font-size: 15px; color: #7a8898; line-height: 1.7; text-align: center;">Prepara tus maletas,&nbsp;<strong style="color: #2d3748">{{customerName}}</strong>.<br />Tu asiento está reservado y listo para un viaje increíble.</p>
            </td>
          </tr>

          <!-- Journey Card -->
          <tr>
            <td style="padding: 0 16px 26px">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #1453a2; border-radius: 18px; overflow: hidden;">
                <tr><td height="4" style="background-color: #4e891f;">&nbsp;</td></tr>
                <tr>
                  <td style="padding: 22px 20px 20px">
                    <table role="presentation" width="100%">
                      <tr>
                        <td valign="top" width="44%">
                          <p style="margin: 0 0 5px; font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #7ab3e8;">>Salida</p>
                          <p style="margin: 0 0 9px; font-size: 15px; font-weight: 800; color: #ffffff;">{{origin}}</p>
                          <p style="margin: 0; font-size: 12px; font-weight: 500; color: #c8ddf7;">{{departureDate}}</p>
                        </td>
                        <td align="center" width="12%">
                          <img src="data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='46' height='46' viewBox='0 0 46 46'%3E%3Ccircle cx='23' cy='23' r='23' fill='%234e891f'/%3E%3Crect x='10' y='13' width='26' height='16' rx='2.5' fill='none' stroke='white' stroke-width='2'/%3E%3Cline x1='10' y1='19' x2='36' y2='19' stroke='white' stroke-width='1.6'/%3E%3Cline x1='18' y1='13' x2='18' y2='29' stroke='white' stroke-width='1.4'/%3E%3Cline x1='28' y1='13' x2='28' y2='29' stroke='white' stroke-width='1.4'/%3E%3Ccircle cx='16' cy='32' r='2.4' fill='white'/%3E%3Ccircle cx='30' cy='32' r='2.4' fill='white'/%3E%3Cline x1='18.4' y1='32' x2='27.6' y2='32' stroke='white' stroke-width='1.6'/%3E%3C/svg%3E" width="46" height="46" style="display: block; margin: 0 auto" />
                        </td>
                        <td valign="top" align="right" width="44%">
                          <p style="margin: 0 0 5px; font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #7ab3e8; text-align: right;">>Llegada</p>
                          <p style="margin: 0 0 9px; font-size: 15px; font-weight: 800; color: #ffffff; text-align: right;">{{destination}}</p>
                          <p style="margin: 0; font-size: 12px; font-weight: 500; color: #c8ddf7; text-align: right;">{{arrivalDate}}</p>
                        </td>
                      </tr>
                    </table>
                    <div style="border-top: 2px dashed rgba(255,255,255,0.2); margin: 20px 0 18px;"></div>
                    <p style="margin: 0; font-size: 13px; color: #c8ddf7;">Duración estimada:&nbsp;<strong style="color: #ffffff">{{duration}}</strong>&nbsp;&middot;&nbsp; Por favor llega 30&nbsp;min antes</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Passenger Info -->
          <tr>
            <td style="padding: 6px 20px 4px">
              <table width="100%">
                <tr>
                  <td valign="middle" width="50" style="padding-right: 14px">
                    <img src="data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='42' height='42' viewBox='0 0 42 42'%3E%3Ccircle cx='21' cy='21' r='21' fill='%23eef4ff'/%3E%3Ccircle cx='21' cy='15.5' r='5.5' fill='none' stroke='%231453a2' stroke-width='2'/%3E%3Cpath d='M10 34c0-6.1 4.9-11 11-11s11 4.9 11 11' fill='none' stroke='%231453a2' stroke-width='2' stroke-linecap='round'/%3E%3C/svg%3E" width="42" height="42" />
                  </td>
                  <td valign="middle">
                    <p style="margin: 0 0 3px; font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #a0aec0;">Pasajero</p>
                    <p style="margin: 0; font-size: 17px; font-weight: 700; color: #2d3748;">{{passengerNames}}</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Divider -->
          <tr><td style="padding: 18px 20px"><div style="border-top: 1px solid #e8ecf1;"></div></td></tr>

          <!-- Terminal -->
          <tr>
            <td style="padding: 0 20px 40px">
              <table width="100%">
                <tr>
                  <td valign="middle" width="50" style="padding-right: 14px">
                    <img src="data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='42' height='42' viewBox='0 0 42 42'%3E%3Ccircle cx='21' cy='21' r='21' fill='%23eef4ff'/%3E%3Cpath d='M21 9a8.5 8.5 0 0 0-8.5 8.5c0 6.375 8.5 16 8.5 16s8.5-9.625 8.5-16A8.5 8.5 0 0 0 21 9z' fill='none' stroke='%231453a2' stroke-width='2'/%3E%3Ccircle cx='21' cy='17.5' r='3' fill='%231453a2'/%3E%3C/svg%3E" width="42" height="42" />
                  </td>
                  <td valign="middle">
                    <p style="margin: 0 0 3px; font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #a0aec0;">Terminal de Embarque</p>
                    <p style="margin: 0; font-size: 15px; font-weight: 600; color: #2d3748;">{{terminalAddress}}</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="background-color: #f6f8fa; border-top: 1px solid #e4e9f0; padding: 20px 24px 24px;">
              <p style="margin: 0 0 5px; font-size: 13px; font-weight: 600; color: #6b7c93;">¡Que tengas un viaje seguro y cómodo!</p>
              <p style="margin: 0; font-size: 11px; color: #b2bec9;">&copy; 2026 Bus Express &nbsp;&middot;&nbsp; Todos los derechos reservados</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>